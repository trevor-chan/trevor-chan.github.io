---
import { getCollection, render } from 'astro:content';
import ProjectLayoutText from '../../layouts/ProjectLayoutText.astro';

export async function getStaticPaths() {
  // Include drafts so template files are accessible as reference pages
  const allProjects = await getCollection('projects', () => true);
  return allProjects.map((entry) => {
    // entry.id is "melanoma/index.mdx" — derive URL slug from directory name
    const slug = entry.id.split('/')[0];
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ProjectLayoutText entry={entry}>
  <Content />
</ProjectLayoutText>
